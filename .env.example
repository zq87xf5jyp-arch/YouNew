# Backend secret. Set only in the backend provider's encrypted secret store.
OPENAI_API_KEY=

# Backend model configuration. The backend must reject models outside its
# explicitly supported GPT-5.6 allowlist and return the actually used model.
OPENAI_MODEL=

# iOS build setting injected into Info.plist. Never place OPENAI_API_KEY here.
YOUNEW_AI_BACKEND_URL=
