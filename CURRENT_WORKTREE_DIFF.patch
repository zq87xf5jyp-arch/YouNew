+    var body: some View {
+        GeometryReader { proxy in
+            ProvinceHighlightMapView(
+                provinceID: selectedProvinceID,
+                highlightColor: selectedProvince?.mapHighlightColor ?? AppColors.dutchOrange,
+                showLabels: showLabels
+            )
+            .contentShape(Rectangle())
+            .gesture(
+                DragGesture(minimumDistance: 0)
+                    .onEnded { value in
+                        selectProvince(at: value.location, in: proxy.size)
+                    }
+            )
+        }
+    }
+
+    private func selectProvince(at location: CGPoint, in size: CGSize) {
+        guard size.width > 0, size.height > 0 else { return }
+        let normalizedPoint = CGPoint(
+            x: min(max(location.x / size.width, 0), 1),
+            y: min(max(location.y / size.height, 0), 1)
+        )
+
+        guard let hitZone = ProvinceHitZones.hitTest(normalizedPoint) else { return }
+        withAnimation(AppAnimations.standard) {
+            selectedProvinceID = hitZone.id
+        }
+
+        #if canImport(UIKit)
+        UIImpactFeedbackGenerator(style: .light).impactOccurred()
+        #endif
+    }
+}
