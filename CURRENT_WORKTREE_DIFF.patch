+    private static func webURLString(for host: String) -> String {
+        if host.hasPrefix("http://") || host.hasPrefix("https://") {
+            return host
+        }
+        if host.hasPrefix("www.") || host.components(separatedBy: ".").count > 2 {
+            return "https://\(host)"
+        }
+        return "https://www.\(host)"
