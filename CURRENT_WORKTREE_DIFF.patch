+struct ResponsiveContentContainer<Content: View>: View {
+    var maxWidth: CGFloat
+    let content: Content
+
+    init(maxWidth: CGFloat = 920, @ViewBuilder content: () -> Content) {
+        self.maxWidth = maxWidth
+        self.content = content()
