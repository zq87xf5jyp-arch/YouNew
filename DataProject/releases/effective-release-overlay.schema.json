{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://younew.nl/schemas/data-project/effective-release-overlay.schema.json",
  "title": "YouNew Data Project effective-release overlay",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "release_id",
    "version",
    "status",
    "work_package",
    "dataset",
    "base_release_id",
    "supersedes",
    "base_batch_sha256",
    "qa",
    "evidence",
    "replacements"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "release_id": {"type": "string", "pattern": "^[a-z0-9]+(?:[._:-][a-z0-9]+)+$"},
    "version": {"type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"},
    "status": {"type": "string", "enum": ["qa", "published", "retired"]},
    "work_package": {"type": "string", "pattern": "^WP-[0-9]{2}$"},
    "dataset": {"type": "string", "minLength": 2},
    "base_release_id": {"type": "string", "pattern": "^[a-z0-9]+(?:[._:-][a-z0-9]+)+$"},
    "supersedes": {"type": "string", "pattern": "^[a-z0-9]+(?:[._:-][a-z0-9]+)+$"},
    "base_batch_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "qa": {"$ref": "#/$defs/qa"},
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/evidence"}
    },
    "replacements": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/replacement"}
    }
  },
  "$defs": {
    "gateResult": {
      "type": "string",
      "enum": ["pending", "passed", "failed", "not_applicable"]
    },
    "qa": {
      "type": "object",
      "additionalProperties": false,
      "required": ["build", "static", "duplicate", "source", "media", "search", "ai"],
      "properties": {
        "build": {"$ref": "#/$defs/gateResult"},
        "static": {"$ref": "#/$defs/gateResult"},
        "duplicate": {"$ref": "#/$defs/gateResult"},
        "source": {"$ref": "#/$defs/gateResult"},
        "media": {"$ref": "#/$defs/gateResult"},
        "search": {"$ref": "#/$defs/gateResult"},
        "ai": {"$ref": "#/$defs/gateResult"}
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "url", "checked_at", "note"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9]+(?:[._:-][a-z0-9]+)+$"},
        "kind": {"type": "string", "enum": ["url_check", "replacement_review"]},
        "url": {"type": "string", "format": "uri", "pattern": "^https://.+$"},
        "checked_at": {"type": "string", "format": "date"},
        "note": {"type": "string", "minLength": 1}
      }
    },
    "replacement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entity_id",
        "original_canonical_sha256",
        "replacement_canonical_sha256",
        "reason",
        "evidence_refs",
        "record"
      ],
      "properties": {
        "entity_id": {"type": "string", "pattern": "^[a-z0-9]+(?:[._:-][a-z0-9]+)+$"},
        "original_canonical_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "replacement_canonical_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "reason": {"type": "string", "minLength": 1},
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[a-z0-9]+(?:[._:-][a-z0-9]+)+$"}
        },
        "record": {
          "type": "object",
          "description": "A full canonical entity. The resolver additionally requires the stable ID and canonical replacement hash to match."
        }
      }
    }
  }
}
