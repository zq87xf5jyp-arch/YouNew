{
  "name": "younew-public-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "next dev",
    "dev:lan": "next dev -H 0.0.0.0 -p 3001",
    "build": "bash scripts/build.sh",
    "start": "node scripts/preview.mjs",
    "generate:content": "node scripts/generate-public-content.mjs",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.ts",
    "test:smoke": "node scripts/smoke-test.mjs",
    "check:links": "node scripts/check-links.mjs",
    "check:security": "node scripts/check-security.mjs",
    "predeploy:check": "bash scripts/pre-deploy.sh"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "next": "16.2.11",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "15.5.19",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
