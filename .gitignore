/IA_Audit_Screenshots/

# Historical local audit exports are not part of the curated Build Week packet.
# BuildWeekAudit/ and BuildWeekFix/ remain explicitly visible below.
/Audit/

# Generated DataProject staging cache; the curated practical-guide wave remains visible.
/DataProject/staging/*
!/DataProject/staging/practical-guides-wave-1.json
/DataProject/reports/

# Generated network-link evidence. Offline static QA uses an explicit sentinel;
# scheduled network jobs regenerate these files as CI artifacts.
/knowledge_data_health.json
/broken_links.csv

# Accidental duplicate exports, never canonical evidence.
* 2.md

# Build Week evidence must not be hidden by generic report patterns.
!BuildWeekAudit/
!BuildWeekAudit/**
!BuildWeekFix/
!BuildWeekFix/**
