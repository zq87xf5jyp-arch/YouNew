"historyNetherlands.periods.prehistory.details" = "Archaeological evidence shows long-term settlement in low river and coastal landscapes. Water, soil, and trade routes shaped where communities could live.";
"historyNetherlands.periods.prehistory.whyItMatters" = "The Dutch relationship with water and landscape began before the country became a state.";
"historyNetherlands.periods.roman.date" = "800 BC–410 AD";
"historyNetherlands.periods.roman.title" = "Celts, Germanic tribes, and Rome";
"historyNetherlands.periods.roman.summary" = "The southern Low Countries became part of the Roman frontier, while Frisian and other Germanic groups lived further north.";
"historyNetherlands.periods.roman.details" = "Roman power reached the southern river area and created forts, roads, and border settlements. North of the frontier, local groups kept different social and trade connections.";
"historyNetherlands.periods.roman.whyItMatters" = "The Roman frontier helps explain later differences between regions of the Low Countries.";
"historyNetherlands.periods.middleAges.date" = "411–1000";
"historyNetherlands.periods.middleAges.title" = "Early Middle Ages";
"historyNetherlands.periods.middleAges.summary" = "After Roman rule declined, local powers, Frisian regions, and Frankish influence shaped the area.";
"historyNetherlands.periods.middleAges.details" = "Power shifted between local rulers, Frisian coastal areas, and Frankish expansion. Trade settlements and church networks gradually connected the region more closely to western Europe.";
"historyNetherlands.periods.middleAges.whyItMatters" = "This period formed early regional identities and trading places.";
"historyNetherlands.periods.towns.date" = "1000–1384";
"historyNetherlands.periods.towns.title" = "Towns and counties";
"historyNetherlands.periods.towns.summary" = "Medieval towns, trade, crafts, and counties such as Holland and Zeeland became increasingly important.";
"historyNetherlands.periods.towns.details" = "City rights, markets, waterways, and local counts shaped everyday life. Towns gained influence because trade, crafts, and taxes mattered to rulers.";
"historyNetherlands.periods.towns.whyItMatters" = "Dutch local government and city culture still reflect medieval urban traditions.";
"historyNetherlands.periods.burgundian.date" = "1384–1482";
"historyNetherlands.periods.burgundian.title" = "Burgundian Netherlands";
"historyNetherlands.periods.burgundian.summary" = "Many Low Countries territories came under Burgundian rule, creating stronger political links between them.";
"historyNetherlands.periods.burgundian.details" = "Burgundian rulers connected separate provinces through court politics, taxation, and shared institutions. The Low Countries became more linked, but local privileges remained important.";
"historyNetherlands.periods.burgundian.whyItMatters" = "Central rule and local rights became a lasting tension in Dutch history.";
"historyNetherlands.periods.habsburg.date" = "1482–1581";
"historyNetherlands.periods.habsburg.title" = "Habsburg Netherlands";
"historyNetherlands.periods.habsburg.summary" = "The Netherlands passed to Habsburg rule. Religious and political conflict increased resistance to Spanish authority.";
"historyNetherlands.periods.habsburg.details" = "The Habsburg period brought stronger central authority and major religious conflict during the Reformation. Resistance grew over taxation, privileges, and repression.";
"historyNetherlands.periods.habsburg.whyItMatters" = "These conflicts led directly into the Dutch Revolt.";
"historyNetherlands.periods.revolt.date" = "1568–1648";
"historyNetherlands.periods.revolt.title" = "Revolt and independence";
"historyNetherlands.periods.revolt.summary" = "The Dutch Revolt led to a long war with Spain and the rise of the Dutch Republic in the northern provinces.";
"historyNetherlands.periods.revolt.details" = "The northern provinces broke with Spanish rule and built the Republic of the Seven United Netherlands. International recognition came with the Peace of Westphalia in 1648.";
"historyNetherlands.periods.revolt.whyItMatters" = "This period created the political foundation of the later Netherlands.";
"historyNetherlands.periods.republic.date" = "1568–1648";
"historyNetherlands.periods.republic.title" = "Revolt and independence";
"historyNetherlands.periods.republic.summary" = "The Dutch Revolt led to a long war with Spain and the rise of the Dutch Republic in the northern provinces.";
"historyNetherlands.periods.republic.details" = "The northern provinces broke with Spanish rule and built the Republic of the Seven United Netherlands. International recognition came with the Peace of Westphalia in 1648.";
"historyNetherlands.periods.republic.whyItMatters" = "This period created the political foundation of the later Netherlands.";
"historyNetherlands.periods.goldenAge.date" = "17th century";
"historyNetherlands.periods.goldenAge.title" = "Dutch Golden Age";
"historyNetherlands.periods.goldenAge.summary" = "The Republic became a maritime and commercial power, with Amsterdam, science, art, finance, and global trade flourishing.";
"historyNetherlands.periods.goldenAge.details" = "Amsterdam grew as a trading and financial centre. Art, science, publishing, shipping, and overseas trade expanded, alongside inequality and colonial exploitation.";
"historyNetherlands.periods.goldenAge.whyItMatters" = "Many famous images of Dutch history come from this period, but its global impact was unequal.";
"historyNetherlands.periods.frenchPeriod.date" = "1795–1815";
"historyNetherlands.periods.frenchPeriod.title" = "French period";
"historyNetherlands.periods.frenchPeriod.summary" = "The Batavian Revolution and Napoleonic era reshaped the country before the modern kingdom was created.";
"historyNetherlands.periods.frenchPeriod.details" = "The old republic ended, and French influence changed administration, law, and state structures. Napoleon's defeat opened the way for a new kingdom.";
"historyNetherlands.periods.frenchPeriod.whyItMatters" = "Modern state institutions were strongly affected by this transition.";
"historyNetherlands.periods.kingdom.date" = "1815";
"historyNetherlands.periods.kingdom.title" = "Kingdom of the Netherlands";
"historyNetherlands.periods.kingdom.summary" = "After Napoleon’s defeat, the Kingdom of the Netherlands was established. Belgium later separated and became independent.";
"historyNetherlands.periods.kingdom.details" = "The post-Napoleonic settlement created a kingdom under the House of Orange. Belgium separated after the Belgian Revolution, and constitutional limits on royal power later became central.";
"historyNetherlands.periods.kingdom.whyItMatters" = "This is the start of the modern Dutch monarchy and state.";
"historyNetherlands.periods.worldWars.date" = "1914–1945";
"historyNetherlands.periods.worldWars.title" = "World wars";
"historyNetherlands.periods.worldWars.summary" = "The Netherlands stayed neutral during World War I but was occupied by Nazi Germany during World War II.";
"historyNetherlands.periods.worldWars.details" = "World War II brought occupation, persecution, resistance, hunger, destruction, and liberation in 1945. Remembrance remains important in public life.";
"historyNetherlands.periods.worldWars.whyItMatters" = "The war deeply shaped modern Dutch memory, law, and public values.";
"historyNetherlands.periods.decolonization.date" = "After 1945";
"historyNetherlands.periods.decolonization.title" = "Recovery and decolonization";
"historyNetherlands.periods.decolonization.summary" = "After the war, the country rebuilt, colonial relations changed, and Indonesia became independent.";
"historyNetherlands.periods.decolonization.details" = "Reconstruction rebuilt housing, infrastructure, and social systems. At the same time, decolonization changed the Kingdom and its relationship with Indonesia, Suriname, and the Caribbean.";
"historyNetherlands.periods.decolonization.whyItMatters" = "Postwar recovery and decolonization still influence Dutch society and migration history.";
"historyNetherlands.periods.modern.date" = "Modern period";
"historyNetherlands.periods.modern.title" = "Modern Netherlands";
"historyNetherlands.periods.modern.summary" = "The Netherlands developed as a parliamentary democracy with strong cities, water management, trade, and a major role in Europe.";
"historyNetherlands.periods.modern.details" = "The country is now a constitutional monarchy and parliamentary democracy. European cooperation, migration, climate adaptation, and urban life are central public themes.";
"historyNetherlands.periods.modern.whyItMatters" = "Understanding modern systems helps newcomers read Dutch society beyond rules and paperwork.";
