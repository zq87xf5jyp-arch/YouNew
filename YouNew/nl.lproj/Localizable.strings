"historyNetherlands.periods.prehistory.date" = "Voor 800 v.Chr.";
"historyNetherlands.periods.prehistory.title" = "Vroege bewoning";
"historyNetherlands.periods.prehistory.summary" = "Mensen woonden al in rivierdelta's en kustgebieden lang voordat de moderne Nederlandse staat bestond.";
"historyNetherlands.periods.prehistory.details" = "Archeologische vondsten tonen langdurige bewoning in lage rivier- en kustlandschappen. Water, bodem en handelsroutes bepaalden waar gemeenschappen konden leven.";
"historyNetherlands.periods.prehistory.whyItMatters" = "De Nederlandse relatie met water en landschap begon al voor het land een staat werd.";
"historyNetherlands.periods.roman.date" = "800 v.Chr.–410 n.Chr.";
"historyNetherlands.periods.roman.title" = "Kelten, Germaanse groepen en Rome";
"historyNetherlands.periods.roman.summary" = "De zuidelijke Lage Landen werden deel van de Romeinse grenszone, terwijl Friese en andere Germaanse groepen noordelijker leefden.";
"historyNetherlands.periods.roman.details" = "Romeinse macht bereikte het zuidelijke rivierengebied met forten, wegen en grensnederzettingen. Ten noorden van de grens hielden lokale groepen andere sociale en handelsbanden.";
"historyNetherlands.periods.roman.whyItMatters" = "De Romeinse grens helpt latere regionale verschillen in de Lage Landen te begrijpen.";
"historyNetherlands.periods.middleAges.date" = "411–1000";
"historyNetherlands.periods.middleAges.title" = "Vroege middeleeuwen";
"historyNetherlands.periods.middleAges.summary" = "Na het verdwijnen van Romeins bestuur kregen lokale machten, Friese gebieden en Frankische invloed meer betekenis.";
"historyNetherlands.periods.middleAges.details" = "Macht verschoof tussen lokale heersers, Friese kustgebieden en Frankische uitbreiding. Handelsplaatsen en kerkelijke netwerken verbonden de regio geleidelijk sterker met West-Europa.";
"historyNetherlands.periods.middleAges.whyItMatters" = "In deze tijd ontstonden vroege regionale identiteiten en handelsplaatsen.";
"historyNetherlands.periods.towns.date" = "1000–1384";
"historyNetherlands.periods.towns.title" = "Steden en graafschappen";
"historyNetherlands.periods.towns.summary" = "Middeleeuwse steden, handel, ambachten en graafschappen zoals Holland en Zeeland werden steeds belangrijker.";
"historyNetherlands.periods.towns.details" = "Stadsrechten, markten, waterwegen en lokale graven vormden het dagelijks leven. Steden kregen meer invloed omdat handel, ambachten en belastingen belangrijk waren voor bestuurders.";
"historyNetherlands.periods.towns.whyItMatters" = "Lokaal bestuur en stadscultuur in Nederland hebben duidelijke middeleeuwse wortels.";
"historyNetherlands.periods.burgundian.date" = "1384–1482";
"historyNetherlands.periods.burgundian.title" = "Bourgondische Nederlanden";
"historyNetherlands.periods.burgundian.summary" = "Veel gebieden in de Lage Landen kwamen onder Bourgondisch bestuur, waardoor sterkere politieke verbindingen ontstonden.";
"historyNetherlands.periods.burgundian.details" = "Bourgondische heersers verbonden afzonderlijke provincies via hofpolitiek, belastingen en gezamenlijke instellingen. De Lage Landen raakten meer verbonden, maar lokale privileges bleven belangrijk.";
"historyNetherlands.periods.burgundian.whyItMatters" = "Centrale macht en lokale rechten werden een blijvende spanning in de Nederlandse geschiedenis.";
"historyNetherlands.periods.habsburg.date" = "1482–1581";
"historyNetherlands.periods.habsburg.title" = "Habsburgse Nederlanden";
"historyNetherlands.periods.habsburg.summary" = "De Nederlanden kwamen onder Habsburgs bestuur. Religieuze en politieke conflicten vergrootten het verzet tegen Spaans gezag.";
"historyNetherlands.periods.habsburg.details" = "De Habsburgse periode bracht sterker centraal bestuur en grote religieuze conflicten tijdens de Reformatie. Verzet groeide rond belastingen, privileges en onderdrukking.";
"historyNetherlands.periods.habsburg.whyItMatters" = "Deze conflicten leidden direct naar de Nederlandse Opstand.";
"historyNetherlands.periods.revolt.date" = "1568–1648";
"historyNetherlands.periods.revolt.title" = "Opstand en onafhankelijkheid";
"historyNetherlands.periods.revolt.summary" = "De Nederlandse Opstand leidde tot een lange oorlog met Spanje en de opkomst van de Republiek in de noordelijke provincies.";
"historyNetherlands.periods.revolt.details" = "De noordelijke provincies braken met het Spaanse gezag en bouwden de Republiek der Zeven Verenigde Nederlanden. Internationale erkenning volgde bij de Vrede van Westfalen in 1648.";
"historyNetherlands.periods.revolt.whyItMatters" = "Deze periode vormde de politieke basis van het latere Nederland.";
"historyNetherlands.periods.republic.date" = "1568–1648";
"historyNetherlands.periods.republic.title" = "Opstand en onafhankelijkheid";
"historyNetherlands.periods.republic.summary" = "De Nederlandse Opstand leidde tot een lange oorlog met Spanje en de opkomst van de Republiek in de noordelijke provincies.";
"historyNetherlands.periods.republic.details" = "De noordelijke provincies braken met het Spaanse gezag en bouwden de Republiek der Zeven Verenigde Nederlanden. Internationale erkenning volgde bij de Vrede van Westfalen in 1648.";
"historyNetherlands.periods.republic.whyItMatters" = "Deze periode vormde de politieke basis van het latere Nederland.";
"historyNetherlands.periods.goldenAge.date" = "17e eeuw";
"historyNetherlands.periods.goldenAge.title" = "Gouden Eeuw";
"historyNetherlands.periods.goldenAge.summary" = "De Republiek werd een maritieme en commerciële macht, met bloei in Amsterdam, wetenschap, kunst, financiën en wereldhandel.";
"historyNetherlands.periods.goldenAge.details" = "Amsterdam groeide als handels- en financieel centrum. Kunst, wetenschap, drukwerk, scheepvaart en overzeese handel namen sterk toe, naast ongelijkheid en koloniale uitbuiting.";
"historyNetherlands.periods.goldenAge.whyItMatters" = "Veel bekende beelden van Nederlandse geschiedenis komen uit deze tijd, maar de wereldwijde impact was ongelijk.";
"historyNetherlands.periods.frenchPeriod.date" = "1795–1815";
"historyNetherlands.periods.frenchPeriod.title" = "Franse tijd";
"historyNetherlands.periods.frenchPeriod.summary" = "De Bataafse Revolutie en de Napoleontische tijd veranderden het land voordat het moderne koninkrijk ontstond.";
"historyNetherlands.periods.frenchPeriod.details" = "De oude republiek eindigde en Franse invloed veranderde bestuur, recht en staatsstructuren. De nederlaag van Napoleon maakte de weg vrij voor een nieuw koninkrijk.";
"historyNetherlands.periods.frenchPeriod.whyItMatters" = "Moderne staatsinstellingen werden sterk beïnvloed door deze overgang.";
"historyNetherlands.periods.kingdom.date" = "1815";
"historyNetherlands.periods.kingdom.title" = "Koninkrijk der Nederlanden";
"historyNetherlands.periods.kingdom.summary" = "Na de nederlaag van Napoleon werd het Koninkrijk der Nederlanden opgericht. België scheidde zich later af en werd onafhankelijk.";
"historyNetherlands.periods.kingdom.details" = "De regeling na Napoleon creëerde een koninkrijk onder het Huis van Oranje. België scheidde zich af na de Belgische Revolutie, en constitutionele grenzen aan koninklijke macht werden later centraal.";
"historyNetherlands.periods.kingdom.whyItMatters" = "Dit is het begin van de moderne Nederlandse monarchie en staat.";
"historyNetherlands.periods.worldWars.date" = "1914–1945";
"historyNetherlands.periods.worldWars.title" = "Wereldoorlogen";
"historyNetherlands.periods.worldWars.summary" = "Nederland bleef neutraal tijdens de Eerste Wereldoorlog, maar werd in de Tweede Wereldoorlog bezet door nazi-Duitsland.";
"historyNetherlands.periods.worldWars.details" = "De Tweede Wereldoorlog bracht bezetting, vervolging, verzet, honger, verwoesting en bevrijding in 1945. Herdenken blijft belangrijk in het openbare leven.";
"historyNetherlands.periods.worldWars.whyItMatters" = "De oorlog heeft moderne Nederlandse herinnering, recht en publieke waarden diep gevormd.";
"historyNetherlands.periods.decolonization.date" = "Na 1945";
"historyNetherlands.periods.decolonization.title" = "Herstel en dekolonisatie";
"historyNetherlands.periods.decolonization.summary" = "Na de oorlog bouwde het land opnieuw op, veranderden koloniale verhoudingen en werd Indonesië onafhankelijk.";
"historyNetherlands.periods.decolonization.details" = "Wederopbouw herstelde woningen, infrastructuur en sociale systemen. Tegelijk veranderde dekolonisatie het Koninkrijk en de relatie met Indonesië, Suriname en het Caribisch gebied.";
"historyNetherlands.periods.decolonization.whyItMatters" = "Wederopbouw en dekolonisatie beïnvloeden nog steeds samenleving en migratiegeschiedenis.";
"historyNetherlands.periods.modern.date" = "Moderne tijd";
"historyNetherlands.periods.modern.title" = "Modern Nederland";
"historyNetherlands.periods.modern.summary" = "Nederland ontwikkelde zich als parlementaire democratie met sterke steden, waterbeheer, handel en een grote rol in Europa.";
"historyNetherlands.periods.modern.details" = "Het land is nu een constitutionele monarchie en parlementaire democratie. Europese samenwerking, migratie, klimaatadaptatie en stedelijk leven zijn centrale publieke thema's.";
"historyNetherlands.periods.modern.whyItMatters" = "Moderne systemen begrijpen helpt nieuwkomers verder te kijken dan regels en papierwerk.";
